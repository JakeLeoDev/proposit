# --- Supabase -----------------------------------------------------------------
# For local dev, run `pnpm db:start` and copy the keys from the CLI output.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ----------------------------------------------------------------------
# Public URL of the app (used in emails, links, OG metadata).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 32 bytes hex-encoded. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Tenant mode --------------------------------------------------------------
# single       — one org, first user becomes admin, further users invite-only (default)
# multi        — open registration, each user creates their own org
# multi-invite — multiple orgs allowed, but self-registration is restricted to
#                emails added to the allowed_registrations table
NEXT_PUBLIC_TENANT_MODE=single

# Shown on the blocked-registration screen (multi-invite mode).
# CONTACT_EMAIL=hello@example.com

# --- Email (SMTP) -------------------------------------------------------------
# Optional. If SMTP_HOST is unset, email features are disabled.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Proposit <hello@example.com>"

# --- PDF export ---------------------------------------------------------------
# The PDF export navigates a headless Chromium to the app's own proposal page.
# By default the function calls back to its own host:
#   - locally → http://localhost:3000
#   - on Vercel → https://$VERCEL_URL (auto)
#   - otherwise → NEXT_PUBLIC_APP_URL
# Set INTERNAL_APP_URL to override (e.g. when running in Docker behind a proxy
# and Chromium needs to reach the app container directly).
# INTERNAL_APP_URL=http://app:3000

# Only used for the non-serverless (full puppeteer) path. Point at a system
# Chromium if you don't want puppeteer to download its bundled version.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
